# ─── Database ─────────────────────────────────────────────────────────────────
# Full async DSN — replace user/password/host/port/dbname as needed
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/expense

# ─── Security ─────────────────────────────────────────────────────────────────
# Long random string used to sign JWTs — generate with: openssl rand -hex 32
APP_SECRET_KEY=change-me-to-a-long-random-secret

# ─── JWT Settings ─────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ──────────────────────────────────────────────────────────────────────
# In development the OTP is always 000000 (mock).
# Set to false in production to use real SMS delivery.
OTP_MOCK=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
